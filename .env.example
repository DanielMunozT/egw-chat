# EGW Research — Environment Variables
# Copy this file to .env and fill in your values.

# Qdrant URL (set automatically by start.sh)
# For shared setups, point this to the admin's Qdrant instance:
#   QDRANT_URL=http://localhost:6333
QDRANT_URL=http://localhost:6333

# Storage directory for Qdrant data (default: .qdrant_storage/ in package dir)
# Set this to a shared path so multiple packages use the same data:
#   EGW_DATA_DIR=/shared/path/to/qdrant_storage
# EGW_DATA_DIR=

# Embedding model (do not change — must match the pre-built snapshots)
EGW_EMBEDDING_MODEL=BAAI/bge-m3

# Optional: EGW API credentials (only needed to download new books)
# EGW_CLIENT_ID=
# EGW_CLIENT_SECRET=
